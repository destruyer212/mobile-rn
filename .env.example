# Copia a .env en la raíz (las apps worker/admin leen el mismo archivo si ejecutas desde el monorepo).

# Supabase (cliente móvil — claves públicas)
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Alternativa publishable key:
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Variante por app (no mezclar en un mismo .env si compilas varias a la vez):
# worker  → apps/worker
# admin   → apps/admin
APP_VARIANT=worker
EXPO_PUBLIC_APP_ROLE=worker

# Solo app admin (Google Maps Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
