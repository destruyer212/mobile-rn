{
  "name": "fleet-control",
  "version": "1.0.0",
  "private": true,
  "description": "Fleet Control monorepo — apps worker y admin; legacy en apps/legacy",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start:worker": "npm run start --workspace=@fleet/app-worker",
    "start:admin": "npm run start --workspace=@fleet/app-admin",
    "start:legacy": "npm run start --workspace=@fleet/app-legacy",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:worker:apk": "npm run build:apk --workspace=@fleet/app-worker",
    "build:admin:apk": "npm run build:apk --workspace=@fleet/app-admin"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
